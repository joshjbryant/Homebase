# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...   # $9.99/mo recurring price ID

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://homebase.app

# ─── Security ────────────────────────────────────────────────
ICAL_FEED_SECRET=generate-a-random-32-char-string
CRON_SECRET=generate-a-random-32-char-string

# ─── Local dev only ──────────────────────────────────────────
# Use Stripe test keys for dev:
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
